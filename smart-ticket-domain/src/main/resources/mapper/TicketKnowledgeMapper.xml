<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartticket.domain.mapper.TicketKnowledgeMapper">

    <insert id="insert" parameterType="com.smartticket.domain.entity.TicketKnowledge"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ticket_knowledge (ticket_id, content, content_summary, status)
        VALUES (#{ticketId}, #{content}, #{contentSummary}, #{status})
    </insert>

    <select id="findById" resultType="com.smartticket.domain.entity.TicketKnowledge">
        SELECT *
        FROM ticket_knowledge
        WHERE id = #{id}
    </select>

    <select id="findByTicketId" resultType="com.smartticket.domain.entity.TicketKnowledge">
        SELECT *
        FROM ticket_knowledge
        WHERE ticket_id = #{ticketId}
    </select>

    <select id="findActive" resultType="com.smartticket.domain.entity.TicketKnowledge">
        SELECT *
        FROM ticket_knowledge
        WHERE status = 'ACTIVE'
        ORDER BY updated_at DESC
    </select>

    <update id="update" parameterType="com.smartticket.domain.entity.TicketKnowledge">
        UPDATE ticket_knowledge
        SET content = #{content},
            content_summary = #{contentSummary},
            status = #{status}
        WHERE id = #{id}
    </update>
</mapper>
