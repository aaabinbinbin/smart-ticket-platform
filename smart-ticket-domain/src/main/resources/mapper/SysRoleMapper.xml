<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartticket.domain.mapper.SysRoleMapper">

    <insert id="insert" parameterType="com.smartticket.domain.entity.SysRole"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_role (role_code, role_name)
        VALUES (#{roleCode}, #{roleName})
    </insert>

    <select id="findById" resultType="com.smartticket.domain.entity.SysRole">
        SELECT id, role_code, role_name, created_at
        FROM sys_role
        WHERE id = #{id}
    </select>

    <select id="findByRoleCode" resultType="com.smartticket.domain.entity.SysRole">
        SELECT id, role_code, role_name, created_at
        FROM sys_role
        WHERE role_code = #{roleCode}
    </select>

    <select id="findAll" resultType="com.smartticket.domain.entity.SysRole">
        SELECT id, role_code, role_name, created_at
        FROM sys_role
        ORDER BY id ASC
    </select>
</mapper>
