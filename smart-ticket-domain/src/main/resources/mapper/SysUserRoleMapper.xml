<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartticket.domain.mapper.SysUserRoleMapper">

    <insert id="insert" parameterType="com.smartticket.domain.entity.SysUserRole"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user_role (user_id, role_id)
        VALUES (#{userId}, #{roleId})
    </insert>

    <select id="findById" resultType="com.smartticket.domain.entity.SysUserRole">
        SELECT *
        FROM sys_user_role
        WHERE id = #{id}
    </select>

    <select id="findByUserId" resultType="com.smartticket.domain.entity.SysUserRole">
        SELECT *
        FROM sys_user_role
        WHERE user_id = #{userId}
        ORDER BY id ASC
    </select>

    <select id="findRolesByUserId" resultType="com.smartticket.domain.entity.SysRole">
        SELECT r.*
        FROM sys_role r
        INNER JOIN sys_user_role ur ON ur.role_id = r.id
        WHERE ur.user_id = #{userId}
        ORDER BY r.id ASC
    </select>
</mapper>
